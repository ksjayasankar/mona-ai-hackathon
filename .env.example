# ---- LLM ----
GEMINI_API_KEY=
LLM_PROVIDER=gemini            # gemini (prod/demo) | ollama (free local dev)
OLLAMA_HOST=http://localhost:11434
# GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Auth (Supabase) ----
AUTH_MODE=dev                  # dev (no token, local) | supabase (verify JWT)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Database ----
DATABASE_URL=                  # postgres/supabase URL; empty -> local SQLite (data/app.db)

# ---- API / web ----
WEB_ORIGIN=http://localhost:3000

# ---- P2 UKS outreach (Twilio SMS; empty -> simulated send that still makes a magic link) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                   # your Twilio number, e.g. +49...
PUBLIC_BASE_URL=http://localhost:3000   # base for the SMS accept magic-link

# ---- P2 UKS roster sync (Google Sheets; empty -> writes data/hospital_schedule_updated.xlsx) ----
GOOGLE_SHEETS_ID=                       # target spreadsheet id (share it with the service account)
GOOGLE_SHEETS_CREDENTIALS_JSON=         # path to a Google service-account key json
GOOGLE_SHEETS_WORKSHEET=Roster          # worksheet/tab name (optional)

# ---- Optional integrations ----
FIRECRAWL_API_KEY=             # enables the web_search agent tool (P4 verify, P7/P8/P9)
GITHUB_TOKEN=                  # raises the github_lookup rate limit (P4 verification); optional
ELEVENLABS_API_KEY=            # nicer P6 reel voiceover (gTTS is the free fallback)
HF_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
